<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yun.studentcourse.course.mapper.CourseScheduleMapper">

    <resultMap id="CourseScheduleResultMap" type="com.yun.studentcourse.course.entity.CourseSchedule">
        <id column="schedule_id" property="scheduleId"/>
        <result column="course_id" property="courseId"/>
        <result column="weekday" property="weekday"/>
        <result column="start_time" property="startTime"/>
        <result column="end_time" property="endTime"/>
        <result column="classroom" property="classroom"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <insert id="insert" parameterType="com.yun.studentcourse.course.entity.CourseSchedule" useGeneratedKeys="true" keyProperty="scheduleId">
        INSERT INTO course_schedule (
            course_id, weekday, start_time, end_time, classroom
        ) VALUES (
            #{courseId}, #{weekday}, #{startTime}, #{endTime}, #{classroom}
        )
    </insert>

    <select id="findByCourseId" resultMap="CourseScheduleResultMap">
        SELECT schedule_id, course_id, weekday, start_time, end_time, classroom, create_time, update_time
        FROM course_schedule
        WHERE course_id = #{courseId}
        ORDER BY weekday ASC, start_time ASC
    </select>
</mapper>

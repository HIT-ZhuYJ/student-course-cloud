<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yun.studentcourse.enrollment.mapper.EnrollmentMapper">

    <resultMap id="EnrollmentResultMap" type="com.yun.studentcourse.enrollment.entity.Enrollment">
        <id column="enrollment_id" property="enrollmentId"/>
        <result column="student_id" property="studentId"/>
        <result column="course_id" property="courseId"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="EnrollmentColumns">
        enrollment_id, student_id, course_id, status, create_time, update_time
    </sql>

    <insert id="insert" parameterType="com.yun.studentcourse.enrollment.entity.Enrollment" useGeneratedKeys="true" keyProperty="enrollmentId">
        INSERT INTO enrollment (
            student_id, course_id, status
        ) VALUES (
            #{studentId}, #{courseId}, #{status}
        )
    </insert>

    <select id="findById" resultMap="EnrollmentResultMap">
        SELECT <include refid="EnrollmentColumns"/>
        FROM enrollment
        WHERE enrollment_id = #{enrollmentId}
    </select>

    <select id="findByStudentIdAndCourseId" resultMap="EnrollmentResultMap">
        SELECT <include refid="EnrollmentColumns"/>
        FROM enrollment
        WHERE student_id = #{studentId}
          AND course_id = #{courseId}
    </select>

    <select id="findActiveByStudentId" resultMap="EnrollmentResultMap">
        SELECT <include refid="EnrollmentColumns"/>
        FROM enrollment
        WHERE student_id = #{studentId}
          AND status = 'ACTIVE'
        ORDER BY enrollment_id ASC
    </select>

    <select id="findByStudentId" resultMap="EnrollmentResultMap">
        SELECT <include refid="EnrollmentColumns"/>
        FROM enrollment
        WHERE student_id = #{studentId}
        ORDER BY enrollment_id DESC
    </select>

    <select id="findPage" resultMap="EnrollmentResultMap">
        SELECT <include refid="EnrollmentColumns"/>
        FROM enrollment
        <where>
            <if test="studentId != null">
                AND student_id = #{studentId}
            </if>
            <if test="courseId != null">
                AND course_id = #{courseId}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        ORDER BY enrollment_id DESC
        LIMIT #{offset}, #{pageSize}
    </select>

    <select id="count" resultType="long">
        SELECT COUNT(1)
        FROM enrollment
        <where>
            <if test="studentId != null">
                AND student_id = #{studentId}
            </if>
            <if test="courseId != null">
                AND course_id = #{courseId}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
    </select>

    <update id="updateStatus">
        UPDATE enrollment
        SET status = #{status}
        WHERE enrollment_id = #{enrollmentId}
    </update>
</mapper>

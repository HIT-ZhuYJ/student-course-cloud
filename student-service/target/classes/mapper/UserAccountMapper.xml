<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yun.studentcourse.student.mapper.UserAccountMapper">

    <resultMap id="UserAccountResultMap" type="com.yun.studentcourse.student.entity.UserAccount">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="password_hash" property="passwordHash"/>
        <result column="role" property="role" javaType="com.yun.studentcourse.common.RoleEnum"/>
        <result column="related_id" property="relatedId"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <insert id="insert" parameterType="com.yun.studentcourse.student.entity.UserAccount" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user_account (
            username, password_hash, role, related_id, status
        ) VALUES (
            #{username}, #{passwordHash}, #{role}, #{relatedId}, #{status}
        )
    </insert>

    <select id="findByUsername" resultMap="UserAccountResultMap">
        SELECT id, username, password_hash, role, related_id, status, create_time, update_time
        FROM user_account
        WHERE username = #{username}
    </select>
</mapper>
